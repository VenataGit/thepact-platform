# Database
DATABASE_URL=postgresql://thepact:your_password@localhost:5432/thepact

# Auth
JWT_SECRET=change_this_to_a_random_64_char_hex_string
BCRYPT_ROUNDS=12

# Server
PORT=3000
NODE_ENV=production

# AI (optional)
ANTHROPIC_API_KEY=sk-ant-...

# Google Calendar (optional — or configure via Admin → Settings)
GOOGLE_CALENDAR_ENABLED=false
GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com
# Place google-credentials.json (Service Account key) in project root

# Push Notifications (generate with: node scripts/generate-vapid-keys.js)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@thepact.pro

# Deploy
DEPLOY_SECRET=change_this
